{
    "dataset":{
        "train_dataset":"./datasets/train",
        "val_dataset":"./datasets/val",
        "max_bbox_shift": 20,
        "num_workers": 4,
        "prompt_mode": "box",
        "min_points": 1,
        "max_points": 3
    },
    "model":{
        "checkpoint_path":"./weights/mobile_sam.pt",
        "type":"vit_t",
        "image_size": 1024,
        "save_path":"./logs"
    },
    "train": {
        "epochs": 10000,
        "learning_rate": 1e-5,
        "batch_size": 4,
        "val_freq": 5,
        "gradient_accumulation": 1,
        "bf16": false,
        "warmup_step": 250,
        "resume": false
    },
    "loss": {
        "focal_weight": 20.0,
        "dice_weight": 1.0,
        "iou_weight": 1.0
    },
    "visual":{
        "status": true,
        "save_path": "./images",
        "IOU_threshold": 0.5
    },
    "freeze":{
        "freeze_image_encoder": true,
        "freeze_prompt_encoder": true,
        "freeze_mask_decoder": false
    },
    "early_stopping": {
        "enabled": true,
        "patience": 20,
        "min_delta": 0.0001,
        "monitor_metric": "val_loss"
    }
}